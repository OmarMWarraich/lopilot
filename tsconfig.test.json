{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": [
      "node",
      "vscode",
      "vitest"
    ]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "vitest.config.mts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".vscode-test"
  ]
}